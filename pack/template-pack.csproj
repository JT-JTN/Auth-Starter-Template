<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageType>Template</PackageType>
    <PackageVersion>1.0.9</PackageVersion>
    <PackageReleaseNotes>v1.0.9 — Template hygiene: exclude EF migrations (consumers run dotnet ef migrations add InitialCreate), TODO.md, test data SQL, and dev-specific files from template output. Replace repo README with a clean getting-started guide. LICENSE copyright now uses a placeholder for consumers to fill in.</PackageReleaseNotes>
    <PackageId>JTNetworx.AuthStarterTemplate</PackageId>
    <Title>ASP.NET Core Auth Starter</Title>
    <Authors>JT Networx</Authors>
    <Company>JT Networx</Company>
    <Description>Full-stack auth starter: ASP.NET Core 10 API + Blazor WASM, Clean Architecture, JWT + refresh tokens, passkeys (WebAuthn), roles, admin panel, audit log, 2FA, GDPR, rate limiting, idempotency, correlation IDs, output caching, SignalR notifications, and localization.</Description>
    <PackageTags>aspnetcore;blazor;blazor-wasm;authentication;jwt;passkeys;webauthn;clean-architecture;identity;signalr;template;dotnet-new</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/JTNetworx/Auth-Starter-Template</PackageProjectUrl>
    <RepositoryUrl>https://github.com/JTNetworx/Auth-Starter-Template</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageIcon>icon-192.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <ContentTargetFolders>content</ContentTargetFolders>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <NoBuild>true</NoBuild>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="..\**\*"
             PackagePath="content\%(RecursiveDir)%(Filename)%(Extension)"
             Exclude="..\**\bin\**;..\**\obj\**;..\**\.git\**;..\**\.vs\**;..\**\.claude\**;..\**\logs\**;..\**\TestResults\**;..\**\*.user;..\**\*.suo;..\pack\**;..\release-artifacts\**;..\TODO.md;..\sql scripts\InsertStaleTestData.sql;..\**\Migrations\**;..\AZURE_SIGNING_SETUP.md" />
    <None Include="..\assets\icon-192.png" Pack="true" PackagePath="\" />
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
