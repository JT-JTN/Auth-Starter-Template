@inject IAuthApiService AuthApi
@inject IUserApiService UserApi
@inject TokenStorageService TokenStorage
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<AuthorizeView>
    <Authorized Context="authCtx">
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
            <ActivatorContent>
                <div @onclick="context.ToggleAsync"
                     class="d-flex align-center gap-2"
                     style="cursor:pointer; user-select:none; padding:4px 8px;">
                    @if (!string.IsNullOrEmpty(_profileImageUrl))
                    {
                        <MudAvatar Style="width:32px; height:32px;">
                            <MudImage Src="@_profileImageUrl" Alt="Profile"
                                      ObjectFit="ObjectFit.Cover"
                                      Style="width:100%; height:100%;" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Color="Color.Primary"
                                   Style="width:32px; height:32px; font-size:.8rem; font-weight:600;">
                            @GetInitials(authCtx)
                        </MudAvatar>
                    }
                    <MudText Typo="Typo.body2" Style="font-weight:500; color:inherit;">
                        @GetDisplayName(authCtx)
                    </MudText>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown"
                             Style="color:inherit; font-size:1.2rem;" />
                </div>
            </ActivatorContent>
            <ChildContent>
                <div class="px-4 py-2" style="min-width:220px;">
                    <MudText Typo="Typo.subtitle2" Style="font-weight:600;">
                        @GetDisplayName(authCtx)
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @authCtx.User.FindFirst("email")?.Value
                    </MudText>
                </div>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">My Profile</MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="LogoutAsync" IconColor="Color.Error">
                    <MudText Color="Color.Error">Sign Out</MudText>
                </MudMenuItem>
            </ChildContent>
        </MudMenu>
    </Authorized>
    <NotAuthorized>
        <MudButton Href="/login" Variant="Variant.Text" Color="Color.Inherit" Class="mr-1">Login</MudButton>
        <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary">Register</MudButton>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string? _profileImageUrl;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true) return;

        var result = await UserApi.GetProfileAsync();
        if (result.IsSuccess && result.Value is not null)
            _profileImageUrl = result.Value.ProfileImageUrl;
    }

    private async Task LogoutAsync()
    {
        var refreshToken = await TokenStorage.GetRefreshTokenAsync();
        if (!string.IsNullOrEmpty(refreshToken))
            await AuthApi.LogoutAsync(refreshToken);

        Nav.NavigateTo("/login", forceLoad: false);
    }

    private static string GetDisplayName(AuthenticationState ctx)
    {
        var given = ctx.User.FindFirst("given_name")?.Value;
        var family = ctx.User.FindFirst("family_name")?.Value;
        if (!string.IsNullOrWhiteSpace(given) || !string.IsNullOrWhiteSpace(family))
            return $"{given} {family}".Trim();
        return ctx.User.Identity?.Name ?? "User";
    }

    private static string GetInitials(AuthenticationState ctx)
    {
        var given = ctx.User.FindFirst("given_name")?.Value;
        var family = ctx.User.FindFirst("family_name")?.Value;
        if (!string.IsNullOrWhiteSpace(given) && !string.IsNullOrWhiteSpace(family))
            return $"{given[0]}{family[0]}".ToUpperInvariant();
        var name = ctx.User.Identity?.Name;
        return string.IsNullOrWhiteSpace(name) ? "?" : name[..1].ToUpperInvariant();
    }
}
